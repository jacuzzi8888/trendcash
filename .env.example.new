# Required: Flask secret key (minimum 32 characters)
NTC_SECRET_KEY=your-secret-key-here-minimum-32-characters-long

# Optional: Separate encryption key (defaults to NTC_SECRET_KEY)
NTC_ENCRYPTION_KEY=your-encryption-key-minimum-32-characters

# Default admin user (created on first run if no users exist)
NTC_DEFAULT_USER=admin
NTC_DEFAULT_PASSWORD=change-this-to-secure-password

# API Keys
GEMINI_API_KEY=your-gemini-api-key
SERPER_API_KEY=your-serper-api-key

# Database (Production - Turso)
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Cache (Production - Redis, optional but recommended)
REDIS_URL=redis://default:password@redis-host:6379

# Error Tracking (Production - Sentry, optional)
SENTRY_DSN=https://your-sentry-dsn

# Debug mode (set to true for local development)
FLASK_DEBUG=false

# Logging
LOG_LEVEL=INFO
